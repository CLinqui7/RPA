PORT=4100
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OUTLOOK_HEADLESS=false
OUTLOOK_MAX_EMAILS=25

# search = usa Outlook Search antes de leer correos. Recomendado para este MVP.
# inbox = lee los correos visibles recientes.
OUTLOOK_SCAN_MODE=search
OUTLOOK_SEARCH_QUERY=subject:"factura american" hasattachments:yes isread:no
OUTLOOK_LOGIN_GRACE_MS=8000
CORS_ORIGIN=

# MVP: descargar únicamente PDFs de correos cuyo asunto contenga este texto.
# Puedes usar alternativas separadas por |, por ejemplo: factura american|invoice american
INVOICE_SUBJECT_FILTER=factura american
INVOICE_DOWNLOAD_ONLY_MATCHING=true
INVOICE_STORAGE_BUCKET=po-documents
INVOICE_LOCAL_DOWNLOAD_DIR=downloads/invoices
INVOICE_RECEIVED_ONLY=true
INVOICE_REQUIRE_UNREAD=true
INVOICE_MARK_AS_READ=true
INVOICE_SKIP_ALREADY_DOWNLOADED=true

# A2000 REST integration
# AMEXTEST write target used during controlled certification.
A2000_BASE_URL=https://amextest.a2000cloud.com:8890/ords/amxtest
A2000_CLIENT_ID=
A2000_CLIENT_SECRET=
A2000_CLIENT_NAME=Linqui

# Upload IDs / payload root keys.
# Production should use dedicated IDs when A2000/GCS provisions them.
A2000_ORDER_HD_UPLOAD_ID=ORDER_HD
A2000_ORDER_LI_UPLOAD_ID=ORDER_LI
A2000_ORDER_HD_PAYLOAD_KEY=ORDER_HD
A2000_ORDER_LI_PAYLOAD_KEY=ORDER_LI

# Safety gates. Leave production writes disabled by default.
A2000_ALLOW_SHARED_UPLOAD_IDS=false
A2000_ALLOW_PRODUCTION_WRITES=
A2000_ORDER_LI_CLEARED=
