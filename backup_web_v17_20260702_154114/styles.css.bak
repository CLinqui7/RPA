:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #182235;
  background: #eef3f8;
}

* { box-sizing: border-box; }
body { margin: 0; min-height: 100vh; background: linear-gradient(135deg, #eef3f8 0%, #f9fbff 48%, #edf6ff 100%); }
button, input { font: inherit; }
button, a { -webkit-tap-highlight-color: transparent; }
button { border: 0; cursor: pointer; }
a { color: inherit; text-decoration: none; }

.app-shell { max-width: 2180px; margin: 0 auto; padding: 20px; }
.hero { display: flex; justify-content: space-between; gap: 24px; align-items: flex-start; padding: 24px; border: 1px solid #dbe5f0; border-radius: 28px; background: rgba(255, 255, 255, .84); box-shadow: 0 20px 60px rgba(15, 23, 42, .08); backdrop-filter: blur(14px); }
.eyebrow, .panel-head span, .section-title span { margin: 0 0 7px; color: #2563eb; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; font-size: 12px; }
.hero h1 { margin: 0; font-size: clamp(30px, 4vw, 52px); line-height: 1; color: #0f172a; letter-spacing: -0.055em; }
.hero p { margin: 12px 0 0; color: #64748b; max-width: 760px; line-height: 1.55; }
.hero-actions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end; max-width: 680px; }
.hero-actions button, .upload-box button, .primary, .link-button { display: inline-flex; align-items: center; justify-content: center; gap: 8px; border-radius: 14px; padding: 11px 14px; background: #fff; border: 1px solid #d7e2ef; color: #1e293b; font-weight: 850; box-shadow: 0 10px 22px rgba(15, 23, 42, .04); }
.hero-actions button:hover, .upload-box button:hover, .link-button:hover { background: #f8fbff; }
button.primary, .primary { background: #0f172a; color: #fff; border-color: #0f172a; }
button:disabled { opacity: .58; cursor: not-allowed; }
.wide { width: 100%; }

.toast { display: flex; align-items: center; gap: 10px; margin: 16px 0; padding: 14px 16px; border-radius: 18px; font-weight: 850; }
.toast.ok { background: #ecfdf5; color: #047857; border: 1px solid #a7f3d0; }
.toast.error { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }

.upload-box { margin: 18px 0; display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 14px; align-items: center; padding: 18px; border-radius: 24px; background: #ffffff; border: 1px dashed #b9c9dc; box-shadow: 0 12px 34px rgba(15, 23, 42, .04); }
.upload-box.dragging { border-color: #2563eb; background: #eff6ff; }
.upload-box input { display: none; }
.upload-box strong { display: block; color: #0f172a; }
.upload-box p { margin: 4px 0 0; color: #64748b; }

.stats-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; margin-bottom: 18px; }
.mini-stat { min-width: 0; display: grid; grid-template-columns: auto 1fr; grid-template-areas: "icon label" "icon value"; gap: 2px 10px; align-items: center; background: #fff; border: 1px solid #dfe8f3; border-radius: 22px; padding: 16px; box-shadow: 0 12px 32px rgba(15, 23, 42, .045); }
.mini-stat svg { grid-area: icon; color: #2563eb; }
.mini-stat span { grid-area: label; color: #64748b; font-size: 12px; font-weight: 850; text-transform: uppercase; letter-spacing: .06em; }
.mini-stat strong { grid-area: value; color: #0f172a; font-size: 25px; line-height: 1; overflow: hidden; text-overflow: ellipsis; }

.workspace-grid { display: grid; grid-template-columns: 320px minmax(560px, 1fr) minmax(620px, 1.15fr); gap: 14px; align-items: start; }
.panel, .detail-card, .batch-panel { background: #fff; border: 1px solid #dfe8f3; border-radius: 26px; box-shadow: 0 18px 48px rgba(15, 23, 42, .06); overflow: hidden; }
.panel-head, .section-title { display: flex; justify-content: space-between; gap: 14px; align-items: center; padding: 18px 20px; border-bottom: 1px solid #edf2f7; }
.panel-head h2, .section-title h2 { margin: 0; color: #0f172a; font-size: 20px; line-height: 1.15; overflow-wrap: anywhere; }
.small-title { padding-bottom: 12px; }

.left-panel { max-height: calc(100vh - 310px); overflow: auto; min-height: 560px; }
.doc-list { display: grid; }
.doc-row { width: 100%; display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 12px; align-items: center; padding: 14px 16px; background: #fff; border-bottom: 1px solid #edf2f7; text-align: left; }
.doc-row:hover { background: #f8fbff; }
.doc-row.active { background: #eff6ff; box-shadow: inset 4px 0 0 #2563eb; }
.doc-icon { width: 38px; height: 38px; display: grid; place-items: center; border-radius: 14px; background: #edf6ff; color: #2563eb; }
.doc-main { min-width: 0; }
.doc-main strong { display: block; color: #0f172a; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.doc-main span, .doc-main small { display: block; color: #64748b; font-size: 12px; margin-top: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.status-badge { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 6px 9px; background: #e2e8f0; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; white-space: nowrap; }
.status-badge.downloaded { background: #dbeafe; color: #1d4ed8; }
.status-badge.parsed { background: #dcfce7; color: #166534; }
.status-badge.needs_mapping { background: #fff7ed; color: #c2410c; }
.status-badge.parse_error { background: #fee2e2; color: #b91c1c; }

.pdf-panel { min-height: 740px; display: flex; flex-direction: column; }
.pdf-frame { width: 100%; min-height: 676px; border: 0; background: #f8fafc; flex: 1; }
.pdf-empty { min-height: 676px; display: grid; place-items: center; text-align: center; color: #64748b; }
.link-button { padding: 9px 12px; font-size: 13px; }

.detail-card { padding-bottom: 18px; max-height: calc(100vh - 130px); overflow: auto; }
.detail-card.empty-card { padding: 38px 24px; display: grid; justify-items: center; text-align: center; color: #64748b; }
.empty-card { padding: 34px 18px; display: grid; justify-items: center; text-align: center; color: #64748b; }
.empty-card h3 { margin: 10px 0 4px; color: #0f172a; }
.empty-card p { margin: 0; line-height: 1.5; }
.notice { display: flex; gap: 10px; margin: 18px; padding: 14px; border-radius: 18px; }
.notice.warning { background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412; }
.field-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; padding: 16px 18px; }
.field { min-width: 0; background: #f8fafc; border: 1px solid #e5eef8; border-radius: 16px; padding: 12px; }
.field span { display: block; color: #64748b; font-size: 12px; margin-bottom: 4px; font-weight: 750; }
.field strong { display: block; color: #0f172a; font-size: 13px; overflow-wrap: anywhere; }
.field.muted-value strong { color: #d97706; }
.totals-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; padding: 0 18px 16px; }
.panel-block { margin: 0 18px 16px; border: 1px solid #e5eef8; border-radius: 18px; padding: 14px; background: #fff; }
.panel-block h3 { margin: 0 0 10px; color: #0f172a; font-size: 15px; }
.danger-block { background: #fff7f7; border-color: #fecaca; }
.missing-list { display: grid; gap: 10px; }
.missing-list strong { color: #0f172a; font-size: 13px; }
.missing-list p, .muted { margin: 4px 0 0; color: #64748b; line-height: 1.45; font-size: 13px; }
.lines-table-wrap { overflow: auto; border-radius: 14px; border: 1px solid #edf2f7; }
.lines-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.wide-lines-table { min-width: 1040px; }
.size-matrix { display: inline-block; min-width: 150px; color: #0f172a; font-weight: 750; line-height: 1.45; }
.lines-table th { background: #f8fafc; color: #475569; text-align: left; padding: 9px; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
.lines-table td { padding: 9px; border-top: 1px solid #edf2f7; color: #1f2937; vertical-align: top; }

.batch-panel { margin-top: 18px; padding-bottom: 10px; }
.batch-list { display: grid; gap: 10px; padding: 0 18px 18px; }
.batch-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px; border: 1px solid #e5eef8; border-radius: 18px; background: #f8fafc; }
.batch-row strong { display: block; color: #0f172a; }
.batch-row span { display: block; color: #64748b; margin-top: 3px; }
.batch-actions { display: flex; flex-wrap: wrap; gap: 8px; }
.batch-actions a { display: inline-flex; align-items: center; gap: 7px; padding: 9px 11px; border-radius: 12px; background: #fff; border: 1px solid #dbe5f0; color: #1d4ed8; font-weight: 850; font-size: 13px; }

.spin { animation: spin .8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

@media (max-width: 1500px) {
  .workspace-grid { grid-template-columns: 320px minmax(520px, 1fr); }
  .detail-card { grid-column: 1 / -1; max-height: none; }
}
@media (max-width: 980px) {
  .hero { display: grid; }
  .hero-actions { justify-content: flex-start; }
  .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .workspace-grid { grid-template-columns: 1fr; }
  .left-panel, .detail-card { max-height: none; }
  .pdf-panel { min-height: 620px; }
  .pdf-frame, .pdf-empty { min-height: 540px; }
}
@media (max-width: 780px) {
  .app-shell { padding: 14px; }
  .hero-actions button, .upload-box, .batch-row { width: 100%; }
  .upload-box { grid-template-columns: 1fr; }
  .stats-grid, .field-grid, .totals-row { grid-template-columns: 1fr; }
  .doc-row { grid-template-columns: auto 1fr; }
  .doc-row .status-badge { grid-column: 2; justify-self: start; }
}
