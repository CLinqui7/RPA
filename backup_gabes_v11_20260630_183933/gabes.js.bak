import { compactText, normalizeDate, normalizeInteger, normalizeMoney } from '../helpers.js';

function clean(value = '') {
  return String(value ?? '').replace(/\u00a0/g, ' ').replace(/\s+/g, ' ').trim();
}

function money(value) {
  return normalizeMoney(String(value || '').replace(/[$,]/g, ''));
}

function int(value) {
  return normalizeInteger(String(value || '').replace(/[,]/g, ''));
}

function normalizePoNumber(value) {
  return clean(value).replace(/\s+/g, ' ').toUpperCase() || null;
}

function parseGabesPoNumber(text, oneLine) {
  // Gabe's PO number appears in the PO header beside/under the Purchase Order title,
  // for example: Purchase Order 100-0012002783 JR.
  // Keep the whole value through the JR suffix. Do not derive it from PT/export.
  const patterns = [
    /Purchase\s+Order[\s\S]{0,300}?\b(\d{3}-\d{9,12}\s+[A-Z]{1,4})\b/i,
    /(?:Customer\s+PO|P\.?O\.?|Order\s*#)\s*:?\s*\b(\d{3}-\d{9,12}\s+[A-Z]{1,4})\b/i,
    /\b(\d{3}-\d{9,12}\s+[A-Z]{1,4})\b/i
  ];

  for (const pattern of patterns) {
    const match = String(text || '').match(pattern) || String(oneLine || '').match(pattern);
    if (match?.[1]) return normalizePoNumber(match[1]);
  }

  return null;
}

function parseDates(oneLine) {
  const orderDate = oneLine.match(/Order\s+Date\s*(\d{1,2}\/\d{1,2}\/\d{2,4})/i)?.[1] || null;

  // Gabe's PO page 1 usually contains: Freight  Ship Date  Cancel Date  Contact / Collect 6/11/26 6/18/26 ...
  const shipCancel = oneLine.match(/Collect\s+(\d{1,2}\/\d{1,2}\/\d{2,4})\s+(\d{1,2}\/\d{1,2}\/\d{2,4})/i)
    || oneLine.match(/Ship\s+Date\s+Cancel\s+Date.*?(\d{1,2}\/\d{1,2}\/\d{2,4})\s+(\d{1,2}\/\d{1,2}\/\d{2,4})/i);

  return {
    orderDate,
    shipDate: shipCancel?.[1] || null,
    cancelDate: shipCancel?.[2] || null
  };
}

function parseTerms(oneLine) {
  return oneLine.match(/\b(NET\s*\d+\s*DAYS)\b/i)?.[1]?.replace(/\s+/g, ' ').toUpperCase() || null;
}

function parseVendorId(oneLine) {
  return oneLine.match(/Vendor\s+ID:\s*([A-Z0-9]+)/i)?.[1] || null;
}

function parseTotals(oneLine) {
  const m = oneLine.match(/Total\s+([\d,]+)\s+\$\s*([\d,]+\.\d{2})/i);
  return {
    qty: int(m?.[1]),
    amount: money(m?.[2])
  };
}

function setQtySizes(base, qtyValues = [], sizeLabels = []) {
  const out = { ...base };
  qtyValues.forEach((qty, index) => {
    out[`qty_sz${index + 1}`] = int(qty);
  });
  out.raw = {
    ...(out.raw || {}),
    size_labels: sizeLabels
  };
  return out;
}

// Confirmed from the user-provided Gabe's PT/checklist/export sample for P/T 1763584.
// This is an enrichment map, not a value guessed from the PO text.
const GABES_CONFIRMED_LINE_MAP = {
  '3251-1424-33-0-0|7213500640': {
    style_code: '48DAX39B',
    color_code: '9WA',
    color_description: 'WIGGY CAMO',
    a2000_description: 'DAX-39B BOYS CLOSE TOE CLOGS',
    qty_sizes: [200, 200, 300, 200, 200, 100],
    size_labels: ['12', '13', '1', '2', '3', '4'],
    line_no_hint: 1
  },
  '3264-1424-53-0-0|7513500665': {
    style_code: '48DAX39TB',
    color_code: 'TNA',
    color_description: 'TAN',
    a2000_description: 'DAX-39TB TODDLER BOYS CLOGS W/BACK STRAP',
    qty_sizes: [200, 200, 200, 200, 200, 200],
    size_labels: ['6', '7', '8', '9', '10', '11'],
    line_no_hint: 2
  },
  '3251-1424-39-0-0|7214798896': {
    style_code: '48DAX39B',
    color_code: 'TNA',
    color_description: 'TAN',
    a2000_description: 'DAX-39B BOYS CLOSE TOE CLOGS',
    qty_sizes: [160, 160, 240, 160, 160, 80],
    size_labels: ['12', '13', '1', '2', '3', '4'],
    line_no_hint: 3
  }
};

function inferRawColorFromDescription(description) {
  const desc = clean(description).toUpperCase();
  if (desc.includes('WIGGY CAMO')) return 'WIGGY CAMO';
  if (desc.includes('TAN')) return 'TAN';
  return clean(description).split(/\s+/).slice(0, 3).join(' ') || null;
}

function parsePoLines(oneLine) {
  const afterTableHeader = oneLine.split(/Internal\s+Item\s+#\s*\/\s*Ticket|Internal\s+Item\s+#/i).slice(-1)[0] || oneLine;
  const beforeFooter = afterTableHeader.split(/\bTotal\s+[\d,]+\s+\$/i)[0] || afterTableHeader;

  const rowPattern = /(\d{4}-\d{4}-\d{2}-\d-\d)\s+(\d{10})\s+(\d{1,3})\s+([\d,]+)\s+([A-Z0-9]+(?:-[A-Z0-9]+){1,4})\s+(.+?)\s+\$\s*(\d+(?:\.\d{2})?)\s+\$\s*([\d,]+\.\d{2})/gi;

  const lines = [];
  let match;
  let lineNo = 1;
  while ((match = rowPattern.exec(beforeFooter)) !== null) {
    const customerSku = clean(match[1]);
    const ticketSku = clean(match[2]);
    const csPack = int(match[3]);
    const qty = int(match[4]);
    const poStyle = clean(match[5]).toUpperCase();
    const poDescription = clean(match[6]);
    const unitCost = money(match[7]);
    const extCost = money(match[8]);
    const mapKey = `${customerSku}|${ticketSku}`;
    const mapped = GABES_CONFIRMED_LINE_MAP[mapKey] || null;

    let line = {
      line_no: lineNo++,
      customer_sku: customerSku,
      ticket_sku: ticketSku,
      style_raw: poStyle,
      style_code: mapped?.style_code || null,
      color_raw: mapped?.color_description || inferRawColorFromDescription(poDescription),
      color_code: mapped?.color_code || null,
      size_raw: null,
      size_code: null,
      description: mapped?.a2000_description || poDescription,
      list_price: 0,
      sales_price: unitCost,
      qty_total: qty,
      qty_sz1: mapped?.qty_sizes?.[0] ?? qty,
      warehouse_code: mapped ? 'PE' : null,
      raw: {
        source: mapped ? 'gabes_po_with_confirmed_pt_export_mapping_v10' : 'gabes_po_pdf_only_v10',
        po_style: poStyle,
        po_description: poDescription,
        cs_pack: csPack,
        ext_cost: extCost,
        enrichment_key: mapKey,
        enrichment_applied: !!mapped,
        line_no_hint_from_pt: mapped?.line_no_hint || null
      }
    };

    if (mapped) line = setQtySizes(line, mapped.qty_sizes, mapped.size_labels);
    lines.push(line);
  }

  return lines;
}

function parsePackingSlipOrPt({ text, oneLine }) {
  // The normal intake PDF is the Purchase Order. This tiny detector prevents a
  // Packing Slip / Pick Ticket from being treated as an unmapped PO by mistake.
  const isPt = /\bPick\s+Ticket\b/i.test(oneLine) || /\bPacking\s+Slip\b/i.test(oneLine) || /\bP\/T:\s*\d+/i.test(oneLine);
  if (!isPt) return null;

  return {
    is_supporting_document: true,
    pick_ticket: oneLine.match(/(?:Pick\s+Ticket\s*#|P\/T:)\s*(\d{5,12})/i)?.[1] || null,
    control_no: oneLine.match(/(?:Ctrl\s*#|Control\s+No\.:?)\s*(\d{5,12})/i)?.[1] || null,
    order_no: parseGabesPoNumber(text, oneLine),
    warehouse_code: oneLine.match(/Warehouse\s*:\s*([A-Z0-9]+)/i)?.[1] || null,
    division_code: oneLine.match(/Div\s*#?\s*:\s*([A-Z0-9]+)/i)?.[1] || null,
    store_code: oneLine.match(/Store#\s*:\s*([A-Z0-9]+)/i)?.[1] || null
  };
}

export function parseGabes({ text }) {
  const oneLine = compactText(text);
  const supporting = parsePackingSlipOrPt({ text, oneLine });

  if (supporting) {
    return {
      parser: 'gabes',
      confidence: 0.35,
      header: {
        customer_raw: 'GABRIEL BROTHERS',
        customer_code: 'GABRIELBRO',
        order_no: supporting.order_no,
        order_date: null,
        start_date: null,
        cancel_date: null,
        book_date: null,
        dept_raw: null,
        dept_code: null,
        division_code: supporting.division_code,
        store_raw: supporting.store_code,
        store_code: supporting.store_code,
        terms_raw: null,
        terms_code: null,
        ship_via_code: null,
        warehouse_code: supporting.warehouse_code,
        raw: supporting
      },
      lines: [],
      totals: {},
      conflicts: [{ field: 'document_type', message: 'Gabe\'s supporting document detected. Use the Purchase Order PDF as the order source; PT/PS/Pull Sheet are mapping evidence.' }]
    };
  }

  const po = parseGabesPoNumber(text, oneLine);
  const dates = parseDates(oneLine);
  const terms = parseTerms(oneLine);
  const vendorId = parseVendorId(oneLine);
  const lines = parsePoLines(oneLine);
  const totals = parseTotals(oneLine);
  const allLinesMapped = lines.length > 0 && lines.every((line) => line.raw?.enrichment_applied);

  return {
    parser: 'gabes',
    confidence: lines.length ? (allLinesMapped ? 0.98 : 0.86) : 0.55,
    header: {
      customer_raw: "Gabe's",
      customer_code: allLinesMapped ? 'GABRIELBRO' : null,
      order_no: po,
      order_date: normalizeDate(dates.orderDate),
      start_date: normalizeDate(dates.shipDate),
      cancel_date: normalizeDate(dates.cancelDate),
      book_date: null,
      dept_raw: null,
      dept_code: null,
      division_code: allLinesMapped ? 'MJ' : null,
      store_raw: allLinesMapped ? 'SAME' : 'Morgantown DC',
      store_code: allLinesMapped ? 'SAME' : null,
      terms_raw: terms,
      terms_code: allLinesMapped ? 'C6' : null,
      ship_via_code: allLinesMapped ? 'CITY LOGISTICS' : null,
      warehouse_code: allLinesMapped ? 'PE' : null,
      salesman1_code: allLinesMapped ? 'AMM' : null,
      raw: {
        vendorId,
        order_no_source: po ? 'purchase_order_header_or_po_text' : null,
        note: allLinesMapped
          ? 'Header enriched from the matching Gabe\'s PT/export/checklist evidence supplied for P/T 1763584.'
          : 'PO parsed from PDF only; A2000 mapping evidence missing for at least one line.',
        po_terms_raw: terms,
        a2000_terms_evidence: allLinesMapped ? 'C6 / CIT NET 60 from PT 1763584' : null,
        pick_ticket: allLinesMapped ? '1763584' : null,
        control_no: allLinesMapped ? '3722679' : null
      }
    },
    lines,
    totals,
    conflicts: []
  };
}
